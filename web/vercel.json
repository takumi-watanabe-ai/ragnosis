{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_EDGE_FUNCTION_URL": {
      "description": "Supabase Edge Function URL for RAG chat endpoint",
      "value": "https://your-project.supabase.co/functions/v1/rag-chat"
    },
    "NEXT_PUBLIC_SUPABASE_KEY": {
      "description": "Supabase Anon/Public Key (optional if using --no-verify-jwt)",
      "value": ""
    }
  }
}
