# Supabase Edge Function URL
# Local development:
NEXT_PUBLIC_EDGE_FUNCTION_URL=http://localhost:54321/functions/v1/rag-chat
# Production (replace with your Supabase project URL):
# NEXT_PUBLIC_EDGE_FUNCTION_URL=https://your-project.supabase.co/functions/v1/rag-chat

# Supabase Key (optional for local dev with --no-verify-jwt)
# Get this from: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_KEY=
