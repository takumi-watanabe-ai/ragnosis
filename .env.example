# LLM Provider: "openrouter" (cloud, paid) or "ollama" (local, free)
LLM_PROVIDER=ollama

# OpenRouter API (for cloud/production)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# Ollama (for local development - free)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:3b-instruct

# Supabase (PostgreSQL + pgvector for RAG and analytics)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Edge Function URL (for local development)
EDGE_FUNCTION_URL=http://localhost:54321/functions/v1/rag-chat
# For production, use: https://your-project.supabase.co/functions/v1/rag-chat

# Ollama URL (for edge function to call Ollama)
OLLAMA_URL=http://host.docker.internal:11434

# HuggingFace (optional, for data collection only)
HUGGINGFACE_API_KEY=your_hf_token_here  # Optional, higher rate limits for fetching model data

# GitHub (optional, for higher rate limits)
GITHUB_API_TOKEN=your_github_token_here  # Optional, 60 req/hr without, 5000 with token

# Data Collection Settings
DATA_REFRESH_DAYS=1  # How often to refresh job data
MAX_JOBS_PER_RUN=200  # Limit for POC phase

# Embedding Settings
EMBEDDING_MODEL=Supabase/gte-small
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Settings
TOP_K_RESULTS=5
CONFIDENCE_THRESHOLD=0.6  # Min score to return answer (avoid hallucinations)

# Development
DEBUG=true
LOG_LEVEL=INFO
